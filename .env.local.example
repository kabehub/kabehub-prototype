# ============================================================
# KabeHub 環境変数サンプル
# ============================================================
# このファイルをコピーして .env.local にリネームしてください。
# cp .env.local.example .env.local
#
# ⚠️ .env.local は絶対にGitにコミットしないでください。
#    （.gitignore に含まれています）
# ============================================================

# ------------------------------------------------------------
# Supabase（必須）
# Supabaseダッシュボード → Project Settings → API から取得
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ------------------------------------------------------------
# AIのAPIキー（任意・使いたいものだけ設定）
# ブラウザのUI（設定ドロワー）から入力することもできます。
# その場合はここへの記入は不要です。
# ------------------------------------------------------------

# Anthropic Claude
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini
# https://aistudio.google.com/
GEMINI_API_KEY=

# OpenAI ChatGPT
# https://platform.openai.com/
OPENAI_API_KEY=
